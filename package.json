  },
  "bugs": {
    "url": "https://github.com/skyzi000/openclaw-open-webui-channels/issues"
  },
  "homepage": "https://github.com/skyzi000/openclaw-open-webui-channels#readme",
  "dependencies": {
    "socket.io-client": "^4.7.0"
  },
